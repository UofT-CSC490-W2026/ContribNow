# Toggle cloud sync (local-only pipeline works with false)
# requires CLOUD_DB_URL to be set correctly
ENABLE_CLOUD_SYNC=false
# Postgres URL for cloud-safe sync (used when ENABLE_CLOUD_SYNC=true or --sync-cloud is passed)
CLOUD_DB_URL=postgresql://user:password@localhost:5432/contribnow

# Workspace/user identity for cloud-safe sync
TENANT_ID=workspace-dev
USER_ID=your-user-id

# Tenant-scoped hash salt (use a long random secret in real usage)
TENANT_SALT=replace-with-a-strong-random-secret

